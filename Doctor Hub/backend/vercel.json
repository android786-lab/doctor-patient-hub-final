{
  "version": 2,
  "installCommand": "npm install",
  "builds": [
    { "src": "api/health.js", "use": "@vercel/node" },
    { "src": "src/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/health", "dest": "api/health.js" },
    { "src": "/(.*)", "dest": "src/index.js" }
  ]
}
