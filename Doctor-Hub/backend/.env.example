PORT=4000
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
API_PUBLIC_URL=http://localhost:4000

# Optional: comma-separated extra origins (preview URLs, custom domains)
# CORS_ALLOWED_ORIGINS=https://preview-frontend.vercel.app,https://preview-admin.vercel.app

# Required for JWT auth (Module 1)
JWT_SECRET=change-me-to-a-long-random-string

# Database: Supabase (PostgreSQL) — NOT MySQL/Sequelize
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy alias (also accepted by backend)
SUPABASE_KEY=

# Legacy doc names (optional; unused when SUPABASE_* is set)
# DB_HOST=
# DB_USER=
# DB_PASS=
# DB_NAME=

# Email (password reset) — use HTTP API on Vercel (SMTP/Gmail often fails on serverless)
#
# Option A — Brevo (recommended for Vercel): https://www.brevo.com
# IMPORTANT: Use API key from "API Keys" tab (starts with xkeysib-)
# NOT the SMTP key (xsmtpsib-) — wrong key causes "Key not found"
# 1. Senders → verify hamzaweb3565@gmail.com (or your sender)
# 2. SMTP & API → API Keys tab → Generate API key → copy xkeysib-...
BREVO_API_KEY=
BREVO_SENDER_EMAIL=your-verified@gmail.com
BREVO_SENDER_FROM="Doctor Hub <your-verified@gmail.com>"
# Only if using xsmtpsib- SMTP key instead (optional):
# BREVO_SMTP_LOGIN=123abc@smtp-brevo.com
#
# Option B — Resend (https://resend.com) — verify domain or use onboarding@resend.dev for testing
RESEND_API_KEY=
RESEND_FROM="Doctor Hub <onboarding@resend.dev>"
#
# Option C — SMTP (works locally; unreliable on Vercel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Doctor Hub <noreply@yourdomain.com>"

# WhatsApp via Twilio (optional — logs to console if unset)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET_KEY=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

ADMIN_EMAIL=
ADMIN_PASSWORD=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
