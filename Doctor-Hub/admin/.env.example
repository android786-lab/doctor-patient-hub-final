# Production: your deployed backend URL (no trailing slash)
VITE_BACKEND_URL=https://your-backend.vercel.app

# Optional — derived from VITE_BACKEND_URL when unset
VITE_API_URL=https://your-backend.vercel.app/api

# Production: your deployed patient frontend URL
VITE_FRONTEND_URL=https://your-frontend.vercel.app

# Display currency label (optional)
VITE_CURRENCY=Rs
